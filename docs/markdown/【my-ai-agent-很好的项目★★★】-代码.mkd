    @Resource
    private VectorStore pgVectorVectorStore;

    private static final String MARKDOWN_DIR = "docs/markdown/";


    private final ChatClient chatClient;

    private static final String SYSTEM_PROMPT_NORMAL = "你是一个AI助手，可以帮助用户解答各种问题。";

    /**
